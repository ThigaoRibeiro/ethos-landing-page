# Ethos Backend — Variáveis de Ambiente

# ============================================================
# GEMINI API
# ============================================================
# Obtenha sua chave em: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# ============================================================
# GOOGLE DRIVE API
# ============================================================
# ID da pasta no Google Drive que contém os documentos do Ethos
# Exemplo: https://drive.google.com/drive/folders/1ABC123xyz  → ID: 1ABC123xyz
GOOGLE_DRIVE_FOLDER_ID=id_da_pasta_no_drive

# ============================================================
# SERVIDOR
# ============================================================
PORT=3001

# Origem permitida para CORS (URL onde a landing page está rodando)
# Em desenvolvimento: http://localhost:3001
# Em produção: https://seudominio.com.br
ALLOWED_ORIGIN=http://localhost:3001

# Chave interna para rotas administrativas, como recarga manual da base documental
ADMIN_KEY=defina_uma_chave_interna_forte_aqui

# ============================================================
# RATE LIMITING
# ============================================================
# Máximo de requisições por IP por janela de tempo
RATE_LIMIT_MAX=10
# Janela de tempo em milissegundos (padrão: 60000 = 1 minuto)
RATE_LIMIT_WINDOW_MS=60000

# ============================================================
# CREDENCIAIS GOOGLE DRIVE
# ============================================================
# Salve as credenciais em:
# - server/credentials/service-account.json
# ou
# - server/credentials/gcp-oauth.keys.json
# - server/credentials/tokens.json
